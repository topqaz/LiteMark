{
  "name": "litemark",
  "private": true,
  "version": "2.1.4",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "cf:d1:create": "wrangler d1 create litemark",
    "cf:d1:migrate:local": "wrangler d1 migrations apply litemark --local",
    "cf:d1:migrate": "wrangler d1 migrations apply litemark --remote",
    "deploy:cloudflare": "VITE_API_BASE_URL= npm run build && wrangler deploy",
    "preview:cloudflare": "VITE_API_BASE_URL= npm run build && wrangler dev",
    "preview": "vite preview"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "element-plus": "^2.11.8",
    "sortablejs": "^1.15.6",
    "vue": "^3.5.12",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/sortablejs": "^1.15.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "typescript": "^5.6.3",
    "vite": "^7.3.1",
    "@cloudflare/workers-types": "^4.20260426.1",
    "wrangler": "^4.0.0"
  },
  "engines": {
    "node": "20.x"
  }
}
